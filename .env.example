# DeepSeek API Key (必填)
DEEPSEEK_API_KEY=your_key_here

# OpenAI API Key（可选，作为 DEEPSEEK_API_KEY 的备选）
# OPENAI_API_KEY=your_openai_key_here

# API 配置（可选，默认使用 configs/default.json 中的值）
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# WebUI 配置（可选）
# LFO_HOST=127.0.0.1
# LFO_PORT=8501